{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "jsx": "react",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "..",
    "declaration": false,
    "sourceMap": true
  },
  "include": [
    "./server.ts",
    "../core/**/*.ts",
    "../server/routes/handlers.ts",
    "../common/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
