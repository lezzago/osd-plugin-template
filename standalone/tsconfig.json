{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "jsx": "react",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "..",
    "declaration": false,
    "sourceMap": true,
    "baseUrl": "..",
    "paths": {}
  },
  "include": [
    "./**/*.ts",
    "./**/*.tsx",
    "../public/components/**/*.tsx",
    "../public/components/**/*.ts",
    "../core/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
