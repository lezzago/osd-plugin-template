{
  "name": "my-osd-plugin-standalone",
  "version": "1.0.0",
  "private": true,
  "description": "Standalone development server for My OSD Plugin",
  "license": "Apache-2.0",
  "scripts": {
    "build": "yarn build:server && yarn build:client",
    "build:server": "npx tsc --project tsconfig.server.json",
    "build:client": "npx webpack --config webpack.config.js",
    "start": "MOCK_MODE=true node dist/standalone/server.js",
    "dev": "MOCK_MODE=true npx ts-node --project tsconfig.server.json server.ts"
  },
  "dependencies": {
    "@opensearch-project/oui": "1.22.1",
    "express": "^4.19.2",
    "moment": "^2.30.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^5.3.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-router-dom": "^5.3.3",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.0",
    "sass": "^1.77.0",
    "sass-loader": "^14.2.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  }
}
