{
  "name": "my-osd-plugin",
  "version": "1.0.0",
  "private": true,
  "description": "OpenSearch Dashboards plugin template with dual-mode architecture",
  "license": "Apache-2.0",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .js,.ts,.tsx --ignore-pattern standalone/dist --ignore-pattern standalone/node_modules",
    "lint:fix": "eslint . --ext .js,.ts,.tsx --fix --ignore-pattern standalone/dist --ignore-pattern standalone/node_modules",
    "build:osd": "npx webpack --config webpack.osd.config.js",
    "build:standalone": "cd standalone && yarn install && yarn build",
    "start:standalone": "cd standalone && yarn start",
    "dev:standalone": "cd standalone && yarn dev",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "build:plugin": "node scripts/build-plugin.js",
    "license:check": "node scripts/check-licenses.js",
    "e2e": "start-server-and-test 'MOCK_MODE=true node standalone/dist/standalone/server.js' http://localhost:3000 'cypress run'"
  },
  "type": "commonjs",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^14.3.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.14.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-router-dom": "^5.3.3",
    "css-loader": "^7.1.2",
    "cypress": "^13.6.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^5.3.0",
    "sass": "^1.77.0",
    "sass-loader": "^14.2.0",
    "start-server-and-test": "^2.0.3",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.2.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.4.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  }
}
